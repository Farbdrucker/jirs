  "query": "\n        UPDATE sprints SET\n            name = COALESCE($1, name),\n            goal = COALESCE($2, goal),\n            start_date = COALESCE($3, start_date),\n            end_date = COALESCE($4, end_date)\n        WHERE id = $5\n        RETURNING id, project_id, name, goal, start_date, end_date, status, created_at\n        ",
