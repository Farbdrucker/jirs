{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT u.id AS user_id, u.username, u.display_name, u.avatar_url,\n               pm.role, pm.joined_at\n        FROM project_members pm\n        JOIN users u ON u.id = pm.user_id\n        WHERE pm.project_id = $1\n        ORDER BY pm.joined_at\n        ",
