  "query": "\n        UPDATE users SET\n            display_name = COALESCE($1, display_name),\n            avatar_url = CASE WHEN $2::boolean THEN $3 ELSE avatar_url END\n        WHERE id = $4\n        RETURNING id, email, username, display_name, avatar_url, created_at\n        ",
