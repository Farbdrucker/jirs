  "query": "\n        SELECT t.id, t.project_id, t.name, t.color, t.created_at\n        FROM tags t\n        JOIN ticket_tags tt ON tt.tag_id = t.id\n        WHERE tt.ticket_id = $1\n        ORDER BY t.name\n        ",
